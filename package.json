{
  "name": "@scopebound/n8n-nodes-scopebound",
  "version": "0.1.0-preview.1",
  "description": "Pre-execution scope enforcement for AI agent workflows. Validates workflow definitions against role-based authorization scopes (SOC1, SOC2, Production Readiness) before they run, with cryptographically signed attestation tokens for audit.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai-agents",
    "agent-governance",
    "scope-enforcement",
    "compliance",
    "soc1",
    "soc2",
    "production-readiness",
    "scopebound"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Scopebound",
    "email": "support@scopebound.ai",
    "url": "https://scopebound.ai"
  },
  "homepage": "https://github.com/scopebound-ai/n8n-nodes-scopebound#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scopebound-ai/n8n-nodes-scopebound.git"
  },
  "bugs": {
    "url": "https://github.com/scopebound-ai/n8n-nodes-scopebound/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/nodes/Scopebound/Scopebound.node.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ScopeboundApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Scopebound/Scopebound.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@scopebound/sdk": "0.1.0-preview.2",
    "@types/node": "^20.0.0",
    "n8n-workflow": "^1.17.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.0"
  }
}
